@{
    ViewBag.Title = "Ana Sayfa";
}

<section class="home-hero">
    <div class="home-hero-content">
        <span class="home-badge">Kişisel planlama sistemi</span>

        <h1>Kişisel Görev ve Ajanda Takip Sistemi</h1>

        <p>
            Görevlerinizi, etkinliklerinizi ve günlük planlarınızı tek ekranda yönetin.
            Tarihe göre takip edin, tamamlanan işleri admin onay süreciyle kontrol altında tutun.
        </p>

        <div class="home-actions">
            @Html.ActionLink("Giriş Yap", "Login", "Home", null, new { @class = "btn btn-primary btn-lg" })
            @Html.ActionLink("Görevleri Gör", "Index", "Agenda", null, new { @class = "btn btn-outline-light btn-lg" })
        </div>
    </div>
</section>

<section class="home-section">
    <div class="home-section-title">
        <span>Öne çıkan özellikler</span>
        <h2>Ajandanızı daha düzenli yönetin</h2>
    </div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <div class="feature-card">
                <div class="feature-number">01</div>
                <h4>Görev Yönetimi</h4>
                <p>
                    Görev ve etkinliklerinizi ekleyebilir, düzenleyebilir, silebilir
                    ve durumlarını kolayca takip edebilirsiniz.
                </p>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="feature-card">
                <div class="feature-number">02</div>
                <h4>Takvim Görünümü</h4>
                <p>
                    Başlangıç ve bitiş tarihleri olan ajanda kayıtları, takvim üzerinde
                    ilgili tüm günlerde görüntülenir.
                </p>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="feature-card">
                <div class="feature-number">03</div>
                <h4>Admin Onayı</h4>
                <p>
                    Kullanıcı tamamlandı yaptığı görevleri admin onaylar.
                    Onaylanan kayıtlar düzenlemeye kapatılır.
                </p>
            </div>
        </div>
    </div>
</section>

<section class="home-section home-process">
    <div class="home-section-title">
        <span>Sistem akışı</span>
        <h2>Basit ve kontrollü görev süreci</h2>
    </div>

    <div class="process-grid">
        <div class="process-item">
            <strong>1</strong>
            <p>Kullanıcı görev veya etkinlik oluşturur.</p>
        </div>

        <div class="process-item">
            <strong>2</strong>
            <p>Görevler liste ve takvim görünümünde takip edilir.</p>
        </div>

        <div class="process-item">
            <strong>3</strong>
            <p>Kullanıcı görevi tamamlandı olarak işaretler.</p>
        </div>

        <div class="process-item">
            <strong>4</strong>
            <p>Admin tamamlanan görevi onaylayarak süreci bitirir.</p>
        </div>
    </div>
</section>
