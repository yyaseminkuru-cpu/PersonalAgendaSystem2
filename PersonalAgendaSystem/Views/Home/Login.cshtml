

@{
    ViewBag.Title = "Giriş Yap";
}

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-5">

            <div class="card">

                <div class="card-header bg-primary text-white text-center">
                    <h3 class="mb-0">Görev Takip Sistemi</h3>
                </div>

                <div class="card-body">

                    <h4 class="text-center mb-4">Giriş Yap</h4>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">
                            @ViewBag.Error
                        </div>
                    }

                    @if (ViewBag.Success != null)
                    {
                        <div class="alert alert-success">
                            @ViewBag.Success
                        </div>
                    }

                    @using (Html.BeginForm("Login", "Home", FormMethod.Post))
                    {
                        <div class="mb-3">
                            <label class="form-label">E-posta</label>
                            <input type="text" name="username" class="form-control" placeholder="E-posta adresinizi giriniz" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Şifre</label>
                            <input type="password" name="password" class="form-control" placeholder="Şifrenizi giriniz" required />
                        </div>

                        <button type="submit" class="btn btn-primary w-100">
                            Giriş Yap
                        </button>
                    }

                    <div class="text-center mt-3">
                        @Html.ActionLink("Hesabınız yok mu? Kayıt olun", "Register", "Home", null, new { @class = "text-decoration-none fw-bold" })
                    </div>

                    <hr />

                    <div class="text-muted small">
                        <p class="mb-1">
                            <strong>Admin:</strong>
                            admin5109@gmail.com / 5109
                        </p>

                        <p class="mb-0">
                            <strong>Kullanıcı:</strong>
                            user1234@gmail.com / 1234
                        </p>
                    </div>

                </div>

            </div>

        </div>

    </div>

</div>
