

@{
    ViewBag.Title = "Giriş Yap";
}

<!-- Bootstrap tasarımı kullanıyoruz.
     Hocanın örneklerinde de Bootstrap vardı.
     Sayfanın daha düzenli ve responsive görünmesini sağlar. -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-5">

            <div class="card shadow">

                <div class="card-header bg-primary text-white text-center">
                    <h3 class="mb-0">Kişisel Görev ve Ajanda Takip Sistemi</h3>
                </div>

                <div class="card-body">

                    <h4 class="text-center mb-4">Giriş Yap</h4>

                    <!-- Eğer kullanıcı adı veya şifre hatalıysa
         Controller tarafındaki ViewBag.Error burada gösterilir. -->
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">
                            @ViewBag.Error
                        </div>
                    }

                    <!-- Form POST metodu ile HomeController içindeki Login action'ına gider.
         Kullanıcı adı ve şifre burada gönderilir. -->
                    @using (Html.BeginForm("Login", "Home", FormMethod.Post))
                    {
                        <div class="mb-3">
                            <label class="form-label">Kullanıcı Adı</label>

                            <!-- name="username" olmalı.
                 Çünkü controller'daki parametre adı string username. -->
                            <input type="text" name="username" class="form-control" placeholder="Kullanıcı adınızı giriniz" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Şifre</label>

                            <!-- name="password" olmalı.
                 Çünkü controller'daki parametre adı string password. -->
                            <input type="password" name="password" class="form-control" placeholder="Şifrenizi giriniz" required />
                        </div>

                        <button type="submit" class="btn btn-primary w-100">
                            Giriş Yap
                        </button>
                    }

                    <hr />

                    <!-- Sistemde kayıtlı test kullanıcı bilgileri -->
                    <div class="text-muted small">
                        <p class="mb-1">
                            <strong>Admin:</strong>
                            admin5109@gmail.com / 5109
                        </p>

                        <p class="mb-0">
                            <strong>Kullanıcı:</strong>
                            user1234@gmail.com / 1234
                        </p>
                    </div>

                </div>

            </div>

        </div>

    </div>

</div>