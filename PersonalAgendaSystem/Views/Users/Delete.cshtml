@model PersonalAgendaSystem.Models.Users

@{
    ViewBag.Title = "Kullanıcı Pasife Al";
}

<h2>Kullanıcı Pasife Al</h2>

<div class="alert alert-warning">
    Bu kullanıcıyı pasife almak istediğinize emin misiniz?
</div>

<table class="table table-bordered">
    <tr>
        <th>Ad Soyad</th>
        <td>@Model.FullName</td>
    </tr>
    <tr>
        <th>Kullanıcı Adı</th>
        <td>@Model.UserName</td>
    </tr>
    <tr>
        <th>E-posta</th>
        <td>@Model.Email</td>
    </tr>
    <tr>
        <th>Rol</th>
        <td>@Model.Role</td>
    </tr>
</table>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(model => model.UserID)

    <button type="submit" class="btn btn-danger">Pasife Al</button>
    <a href="@Url.Action("Index", "Users")" class="btn btn-secondary ms-2">Vazgeç</a>
}
