@model List<PersonalAgendaSystem.Models.Users>

@{
    ViewBag.Title = "Kullanici Listesi";
}

<div class="page-hero">
    <div>
        <p class="page-eyebrow">Yonetim paneli</p>
        <h2>Kullanici Listesi</h2>
        <p class="page-subtitle">Kullanici hesaplarini, rollerini ve aktiflik durumlarini buradan yonetin.</p>
    </div>
    <div class="hero-actions">
        <a href="@Url.Action("Create", "Users")" class="btn btn-success">Yeni Kullanici Ekle</a>
    </div>
</div>

<div class="metric-grid">
    <div class="metric-card">
        <span>Toplam Kullanici</span>
        <strong>@(Model == null ? 0 : Model.Count)</strong>
    </div>
    <div class="metric-card">
        <span>Aktif</span>
        <strong>@(Model == null ? 0 : Model.Count(x => x.IsActive))</strong>
    </div>
    <div class="metric-card">
        <span>Admin</span>
        <strong>@(Model == null ? 0 : Model.Count(x => x.Role == "Admin"))</strong>
    </div>
</div>

@using (Html.BeginForm("Index", "Users", FormMethod.Get))
{
    <div class="row mb-3">
        <div class="col-md-4">
            <label class="form-label">Arama</label>
            <input type="text" name="search" class="form-control" value="@ViewBag.Search" placeholder="Ad, kullanici adi veya e-posta" />
        </div>

        <div class="col-md-3">
            <label class="form-label">Rol</label>
            @Html.DropDownList("role",
                new SelectList(new[]
                {
                    new SelectListItem { Text = "Admin", Value = "Admin" },
                    new SelectListItem { Text = "Kullanici", Value = "Kullanici" }
                }, "Value", "Text", ViewBag.Role),
                "Tum Roller",
                new { @class = "form-control" })
        </div>

        <div class="col-md-5 d-flex align-items-end filter-actions">
            <button type="submit" class="btn btn-primary me-2">Filtrele</button>
            @Html.ActionLink("Temizle", "Index", "Users", null, new { @class = "btn btn-secondary" })
        </div>
    </div>
}

@if (Model == null || Model.Count == 0)
{
    <div class="alert alert-warning text-center">
        Kayitli kullanici bulunamadi.
    </div>
}
else
{
    <table class="table table-bordered table-striped app-table">
        <thead>
            <tr>
                <th>Ad Soyad</th>
                <th>Kullanici Adi</th>
                <th>E-posta</th>
                <th>Rol</th>
                <th>Durum</th>
                <th class="actions-column">Islemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.FullName</td>
                    <td>@item.UserName</td>
                    <td>@item.Email</td>
                    <td>@item.Role</td>
                    <td>
                        @if (item.IsActive)
                        {
                            <span class="badge bg-success">Aktif</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Pasif</span>
                        }
                    </td>
                    <td class="actions-column">
                        <div class="action-buttons d-flex flex-nowrap">
                            @Html.ActionLink("Detay", "Details", "Users", new { id = item.UserID }, new { @class = "btn btn-info btn-sm" })
                            <a href="@Url.Action("Edit", "Users", new { id = item.UserID })" class="btn btn-warning btn-sm">Duzenle</a>

                            @if (item.IsActive)
                            {
                                @Html.ActionLink("Pasife Al", "Delete", "Users", new { id = item.UserID }, new { @class = "btn btn-danger btn-sm" })
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
