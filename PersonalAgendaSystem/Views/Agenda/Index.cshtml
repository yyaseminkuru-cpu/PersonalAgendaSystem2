@model List<PersonalAgendaSystem.Models.AgendaItems>

@{
    ViewBag.Title = "Görev Listesi";
}

<div class="page-hero">
    <div>
        <p class="page-eyebrow">Kişisel planlama paneli</p>
        <h2>Görev Listesi</h2>
        <p class="page-subtitle">Görevleri takip et, filtrele, tamamla ve admin onay sürecini tek ekrandan yönet.</p>
    </div>
    <div class="hero-actions">
        @Html.ActionLink("Takvim Görünümü", "Calendar", "Agenda", null, new { @class = "btn btn-info me-2" })
        @Html.ActionLink("Yeni Görev Ekle", "Create", "Agenda", null, new { @class = "btn btn-success" })
    </div>
</div>

<div class="metric-grid">
    <div class="metric-card">
        <span>Toplam Görev</span>
        <strong>@(Model == null ? 0 : Model.Count)</strong>
    </div>
    <div class="metric-card">
        <span>Tamamlanan</span>
        <strong>@(Model == null ? 0 : Model.Count(x => x.Status == "Tamamlandı" || x.Status == "Onaylandı"))</strong>
    </div>
    <div class="metric-card">
        <span>Onay Bekleyen</span>
        <strong>@(Model == null ? 0 : Model.Count(x => x.Status == "Tamamlandı" && x.IsApproved == false))</strong>
    </div>
</div>

@using (Html.BeginForm("Index", "Agenda", FormMethod.Get))
{
    <div class="row mb-3">
        <div class="col-md-3">
            <label class="form-label">Öncelik</label>
            @Html.DropDownList("priority",
                new SelectList(new[] { "Acil", "Aktif", "Bekleyebilir" }, ViewBag.Priority),
                "Tüm Öncelikler",
                new { @class = "form-control" })
        </div>

        <div class="col-md-3">
            <label class="form-label">Durum</label>
            @Html.DropDownList("status",
                new SelectList(new[] { "Bekliyor", "Devam Ediyor", "Süresi Geçti", "Tamamlandı", "Onaylandı", "İptal Edildi" }, ViewBag.Status),
                "Tüm Durumlar",
                new { @class = "form-control" })
        </div>

        <div class="col-md-3">
            <label class="form-label">Tarih</label>
            <input type="date" name="filterDate" class="form-control"
                   value="@(ViewBag.FilterDate != null ? ((DateTime)ViewBag.FilterDate).ToString("yyyy-MM-dd") : "")" />
        </div>

        <div class="col-md-3 d-flex align-items-end filter-actions">
            <button type="submit" class="btn btn-primary me-2">Filtrele</button>
            @Html.ActionLink("Temizle", "Index", "Agenda", null, new { @class = "btn btn-secondary" })
        </div>
    </div>
}

@if (Model == null || Model.Count == 0)
{
    <div class="alert alert-warning text-center">
        Kayıtlı görev bulunamadı.
    </div>
}
else
{
    <table class="table table-bordered table-striped app-table">
        <thead>
            <tr>
                <th>Başlık</th>
                <th>Açıklama</th>
                <th>Başlangıç Tarihi</th>
                <th>Bitiş Tarihi</th>
                <th>Öncelik</th>
                <th>Durum</th>
                <th>Onay Durumu</th>
                <th class="actions-column">İşlemler</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Title</td>
                    <td>@item.Description</td>
                    <td>@item.StartDate.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@item.EndDate.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@item.Priority</td>
                    <td>@item.Status</td>
                    <td>
                        @if (item.IsApproved == true)
                        {
                            <span class="badge bg-success">Onaylandı</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">Onay Bekliyor</span>
                        }
                    </td>
                    <td class="actions-column">
                        <div class="action-buttons">
                            @Html.ActionLink("Detay", "Details", "Agenda", new { id = item.AgendaItemId }, new { @class = "btn btn-info btn-sm" })

                            @if (item.IsApproved == false)
                            {
                                @Html.ActionLink("Düzenle", "Edit", "Agenda", new { id = item.AgendaItemId }, new { @class = "btn btn-warning btn-sm" })
                            }

                            @Html.ActionLink("Sil", "Delete", "Agenda", new { id = item.AgendaItemId }, new { @class = "btn btn-danger btn-sm" })

                            @if (item.Status != "Tamamlandı" && item.Status != "Onaylandı" && item.Status != "İptal Edildi")
                            {
                                @Html.ActionLink("Tamamla", "Complete", "Agenda", new { id = item.AgendaItemId }, new { @class = "btn btn-primary btn-sm" })
                            }

                            @if (Session["Role"] != null && Session["Role"].ToString() == "Admin" && item.Status == "Tamamlandı")
                            {
                                @Html.ActionLink("Onayla", "Approve", "Agenda", new { id = item.AgendaItemId }, new { @class = "btn btn-success btn-sm" })
                            }
                        </div>
                    </td>
                </tr>
            }

        </tbody>
    </table>
}
