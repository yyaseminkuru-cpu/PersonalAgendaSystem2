@model PersonalAgendaSystem.Models.AgendaItems

@{
    ViewBag.Title = "Ajanda Onayla";
}

<h2>Ajanda Onayla</h2>
<div class="alert alert-success">
    Bu tamamlanan ajanda kaydını onaylamak istediğinize emin misiniz?
</div>

<table class="table table-bordered">
    <tr>
        <th>Başlık</th>
        <td>@Model.Title</td>
    </tr>
    <tr>
        <th>Açıklama</th>
        <td>@Model.Description</td>
    </tr>
    <tr>
        <th>Kategori</th>
        <td>@Model.Categories.CategoryName</td>
    </tr>
    <tr>
        <th>Başlangıç Tarihi</th>
        <td>@Model.StartDate.ToString("dd.MM.yyyy HH:mm")</td>
    </tr>
    <tr>
        <th>Bitiş Tarihi</th>
        <td>@Model.EndDate.ToString("dd.MM.yyyy HH:mm")</td>
    </tr>
    <tr>
        <th>Öncelik</th>
        <td>@Model.Priority</td>
    </tr>
    <tr>
        <th>Mevcut Durum</th>
        <td>@Model.Status</td>
    </tr>
</table>

// onaylama işlemi için form

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(model => model.AgendaItemId)

    <button type="submit" class="btn btn-success">Onayla</button>
    @Html.ActionLink("Vazgeç", "Index", "Agenda", null, new { @class = "btn btn-secondary ms-2" })
}
